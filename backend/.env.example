# SmartFridge Backend - Environment Configuration Example

# ========================================
# DATABASE CONFIGURATION (PROD)
# ========================================
# PostgreSQL connection string
# Format: jdbc:postgresql://HOST:PORT/DATABASE
DB_URL=jdbc:postgresql://localhost:5432/smartfridge

# PostgreSQL username
DB_USER=smartfridge

# PostgreSQL password
DB_PASS=change-this-secure-password

# ========================================
# JWT CONFIGURATION (PROD)
# ========================================
# JWT secret key for signing tokens
# REQUIREMENTS:
# - Minimum 32 characters
# - Use strong random characters
# - KEEP SECURE AND NEVER EXPOSE
# Generate strong secret:
#   Linux/macOS: openssl rand -base64 32
#   PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Max 256) }))
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-here

# ========================================
# CORS CONFIGURATION (PROD)
# ========================================
# Allowed origins for CORS requests
# Format: comma-separated list of URLs
# Examples: https://app.seudominio.com,https://webapp.seudominio.com
CORS_ALLOWED_ORIGINS=https://app.seudominio.com,https://api.seudominio.com

# ========================================
# SPRING PROFILE (DEV/PROD)
# ========================================
# Profile to use
# Options: dev (H2), prod (PostgreSQL)
# Leave empty or remove for default (dev)
# Set via command: -Dspring-boot.run.profiles=prod
SPRING_PROFILES_ACTIVE=prod

# ========================================
# OPTIONAL: JPA/HIBERNATE
# ========================================
# DDL strategy for database schema
# Options: validate, create, create-drop, update
# For production: use 'validate' (manual migrations recommended)
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ========================================
# OPTIONAL: LOGGING
# ========================================
# Logging level
# Options: DEBUG, INFO, WARN, ERROR
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SMARTFRIDGE=DEBUG

# ========================================
# OPTIONAL: SERVER
# ========================================
# Server port
SERVER_PORT=8080

# Server servlet context path
# Default: /
# Example: /api/v1
SERVER_SERVLET_CONTEXT_PATH=/

# ========================================
# HOW TO USE
# ========================================
#
# 1. DEVELOPMENT (H2 Database)
#    No configuration needed, use defaults
#    cd backend && mvn spring-boot:run
#
# 2. PRODUCTION (PostgreSQL)
#    Copy this file to: backend/.env
#    Fill in all required variables (marked with *)
#    Run with: cd backend && mvn spring-boot:run -Dspring-boot.run.profiles=prod
#
# 3. DOCKER
#    Set environment variables when running container:
#    docker run -e DB_URL=... -e DB_USER=... -e JWT_SECRET=... ...
#
# 4. CI/CD GITHUB ACTIONS
#    Set secrets in: Settings > Secrets and variables > Actions
#    Reference in workflow: ${{ secrets.JWT_SECRET }}
#
# ========================================
# SECURITY REMINDERS
# ========================================
#
# DO NOT:
#   ❌ Commit .env file to repository
#   ❌ Share JWT_SECRET
#   ❌ Use weak passwords (DB_PASS)
#   ❌ Expose passwords in logs
#
# DO:
#   ✅ Add .env to .gitignore
#   ✅ Use strong passwords (20+ chars)
#   ✅ Rotate secrets regularly
#   ✅ Use CI/CD secrets for production
#   ✅ Store backups in secure location
#
